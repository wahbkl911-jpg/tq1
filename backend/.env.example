# 服务器配置
PORT=3001
NODE_ENV=development

# JWT 密钥（生产环境必须修改）
JWT_SECRET=your-super-secret-key-change-in-production

# 数据库配置（SQLite 无需额外配置）
# 数据库文件位于 src/data/database.sqlite

# ============================================
# AI 服务配置
# ============================================

# AI 提供商选择: openai, azure, baidu, aliyun
AI_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
# 如果使用代理或第三方兼容服务，可设置基础URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI 配置（如果使用 Azure）
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# 百度文心一言配置（如果使用百度）
# BAIDU_API_KEY=your-baidu-api-key
# BAIDU_SECRET_KEY=your-baidu-secret-key

# 阿里通义千问配置（如果使用阿里）
# ALIYUN_API_KEY=your-aliyun-api-key
# ALIYUN_MODEL=qwen-turbo

# ============================================
# 字节火山引擎 - 火山方舟配置
# ============================================
# 1. 访问 https://console.volcengine.com/ark
# 2. 创建推理接入点，获取接入点 ID (以 ep- 开头)
# 3. 在【API Key 管理】中创建并获取 API Key

# VOLCANO_API_KEY=your-volcano-api-key
# VOLCANO_MODEL=ep-xxxxxxxxxxxxx  # 你的推理接入点 ID
